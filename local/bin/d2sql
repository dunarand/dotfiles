#!/usr/bin/env bash
set -euo pipefail

# --- Require active venv ---
if [[ -z "${VIRTUAL_ENV:-}" ]]; then
    echo "Error: No virtual environment active (pandas required)." >&2
    exit 1
fi

if ! command -v python >/dev/null 2>&1; then
    echo "Error: python not found in PATH." >&2
    exit 1
fi

# Defaults
TABLE_NAME="data"
MODE=""
INPUT=""
OUTPUT=""

# --- Parse args ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|-c)
            MODE="$1"
            shift
            ;;
        -t)
            TABLE_NAME="$2"
            shift 2
            ;;
        *)
            if [[ -z "$INPUT" ]]; then
                INPUT="$1"
            elif [[ -z "$OUTPUT" ]]; then
                OUTPUT="$1"
            else
                echo "Unexpected argument: $1" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

# --- Validate ---
if [[ -z "$MODE" || -z "$INPUT" || -z "$OUTPUT" ]]; then
    echo "Usage: csvsqlite -p|-c [-t table_name] inputfile output.db" >&2
    exit 1
fi

case "$MODE" in
    -p) FILETYPE="parquet" ;;
    -c) FILETYPE="csv" ;;
esac

# --- Python conversion ---
python - <<EOF
import pandas as pd
import sqlite3
import sys

ft = "$FILETYPE"
inp = "$INPUT"
out = "$OUTPUT"
table = "$TABLE_NAME"

try:
    if ft == "csv":
        df = pd.read_csv(inp)
    else:
        df = pd.read_parquet(inp)
except Exception as e:
    sys.exit(f"Failed to read input file: {e}")

conn = sqlite3.connect(out)
df.to_sql(table, conn, index=False, if_exists="replace")
conn.close()
EOF
